#VRML_SIM R2025a utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2023a/projects/objects/backgrounds/protos/TexturedBackground.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2023a/projects/objects/backgrounds/protos/TexturedBackgroundLight.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2023a/projects/objects/floors/protos/RectangleArena.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2023a/projects/appearances/protos/SandyGround.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2023b/projects/humans/pedestrian/protos/Pedestrian.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/robots/dji/mavic/protos/Mavic2Pro.proto"

WorldInfo {
  info [
    "Patrulha aerea autonoma do exterior de um edificio complexo."
    "Drone Mavic 2 Pro percorre uma rota de waypoints, desviando de"
    "obstaculos conhecidos e reagindo a anomalias (cubos e intrusos)."
  ]
  title "Drone Patrol - Building Exterior"
  lineScale 0.5
}
Viewpoint {
  orientation -0.35 0.30 0.88 1.7
  position -22 -28 46
  followSmoothness 0
}
TexturedBackground {
}
TexturedBackgroundLight {
}
DEF ARENA RectangleArena {
  translation 9 9 0
  floorSize 80 80
  floorTileSize 4 4
  floorAppearance SandyGround {
  }
  wallThickness 0.3
  wallHeight 0.8
}

# ======================= EDIFICIO (obstaculo conhecido) =======================
DEF BUILDING_S_WALL Solid {
  translation 10 0 2.5
  children [
    DEF WALL_SHAPE Shape {
      appearance PBRAppearance {
        baseColor 0.82 0.80 0.76
        roughness 1
        metalness 0
      }
      geometry Box {
        size 20.4 0.4 5
      }
    }
  ]
  name "building_s_wall"
  boundingObject USE WALL_SHAPE
}
