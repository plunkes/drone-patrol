# ======================= ANOMALIAS: CUBOS VERMELHOS (solidos) =======================
DEF RED_CUBE_1 Solid {
  translation 12 -7 0.25
  children [
    DEF RED_CUBE_SHAPE Shape {
      appearance PBRAppearance {
        baseColor 1 0 0
        roughness 0.4
        metalness 0
      }
      geometry Box {
        size 0.5 0.5 0.5
      }
    }
  ]
  name "red_cube_1"
  boundingObject USE RED_CUBE_SHAPE
  recognitionColors [
    1 0 0
  ]
}
DEF RED_CUBE_2 Solid {
  translation 30 20 0.25
  children [
    USE RED_CUBE_SHAPE
  ]
  name "red_cube_2"
  boundingObject USE RED_CUBE_SHAPE
  recognitionColors [
    1 0 0
  ]
}
DEF RED_CUBE_3 Solid {
  translation -8 12 0.25
  children [
    USE RED_CUBE_SHAPE
  ]
  name "red_cube_3"
  boundingObject USE RED_CUBE_SHAPE
  recognitionColors [
    1 0 0
  ]
}

