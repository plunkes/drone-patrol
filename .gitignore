# === Webots Simulation Files ===
# Project-specific preferences and window layout adjustments
.webots_*.wbproj
*.wbproj

# Cache generated by Webots during simulations
.pwbproj.cache
.pwbproj.lock

# === Compiled Binaries & Object Files ===
# Shared libraries and object code generated during controller builds
*.so
*.o
*.d
*.dll
*.dylib

# === Controller Executables ===
# Ignore specific compiled executable binaries inside your controllers folder.
# Example: If your controller folder is named 'my_controller' and generates a binary of the same name:
# /controllers/my_controller/my_controller

# If you use C/C++ controllers, you can ignore all files in the controller build directories
**/controllers/*/build/
**/plugins/physics/*/build/

# === Python / Language Specifics ===
# Ignore Python cache if your controllers are written in Python
__pycache__/
*.pyc

# === IDE & OS Metadata ===
.DS_Store
.vscode/
.idea/
